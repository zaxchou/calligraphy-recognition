# =============================================
# 书法碑帖字体认证系统 - 环境变量配置
# =============================================
# 复制此文件为 .env 并填入你的真实密钥

# --- AI 服务密钥 ---

# SiliconFlow API Key (必需 - 字体识别)
# 从 https://siliconflow.cn/ 获取
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 阿里云 DashScope / Qwen API Key (必需 - 构图分析/题跋)
QWEN_API_KEY=your_qwen_api_key_here

# 百度 OCR API Key (可选 - 百度OCR识别)
BAIDU_OCR_API_KEY=your_baidu_api_key_here
BAIDU_OCR_SECRET_KEY=your_baidu_secret_key_here

# DeepSeek API Key (可选，已弃用)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- 向量数据库 ---

# Qdrant 配置 (构图分析模块使用)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key_here

# --- 构图模块 ---

# 构图分析 API Key (为空则不验证)
# COMPOSITION_API_KEY=your_composition_api_key_here

# 构图 LLM 模型配置
# COMPOSITION_LLM_MODEL=qwen3.5-plus
# COMPOSITION_LLM_MAX_TOKENS=1400

# --- 服务配置 ---

# 后端端口 (默认 8001)
# SERVER_PORT=8001

# CORS 允许的来源 (逗号分隔，* 表示允许所有)
# CORS_ALLOW_ORIGINS=*

# --- 数据库/缓存 (可选) ---

# DATABASE_URL=sqlite:///data/calligraphy.db
# REDIS_URL=redis://localhost:6379/0
